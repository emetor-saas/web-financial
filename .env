# Em desenvolvimento, o Vite faz proxy de `/api` para este endereço (veja vite.config.ts).
# O apiClient usa URL relativa em DEV, então as chamadas vão para o mesmo host e caem no proxy.
VITE_API_URL=http://localhost:3001

# Build de produção (Docker): não defina VITE_API_URL — o nginx repassa `/api` para o backend
# e o frontend usa URLs relativas.
